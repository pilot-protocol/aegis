# Copy this file to .env and adjust for your environment.
# These are placeholder values, not real secrets.

# Server
PORT=8080
LOG_LEVEL=info

# Database
DB_PATH=./data/quill.db

# Auth (generate your own; this is a placeholder)
JWT_SECRET=replace-me-with-a-long-random-string
TOKEN_TTL_MINUTES=60

# Backups
BACKUP_DIR=/var/backups/quill
DB_NAME=quill

# Optional Redis cache
REDIS_URL=redis://localhost:6379/0
